# ============================================================
# HTTPS + WWW → sans-www
# ============================================================
RewriteEngine On

RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ============================================================
# Redirections liens partenaires (cloaking affiliation)
# Centralise les liens d'affiliation derrière /go/<partenaire>/.
# Modifier une URL ici suffit, plus besoin de toucher les avis.
# Ces URLs sont bloquées dans robots.txt et marquées sponsored/nofollow.
# ============================================================
RewriteRule ^go/meetic/?$ https://www.meetic.fr/ [R=302,L,NE,QSD]
RewriteRule ^go/edarling/?$ https://www.edarling.fr/ [R=302,L,NE,QSD]
RewriteRule ^go/infinite-rencontre/?$ https://k.related-dating.com/?abc=79644065a55df209&xa=n&acme=wid.85377&media=seo&source=irmsr&tpls=3 [R=302,L,NE,QSD]
RewriteRule ^go/rencontres-locales/?$ https://k.related-dating.com/?abc=dab7a69b1856f941&xa=n&acme=wid.85377&media=seo&source=rlmsr&tpls=18 [R=302,L,NE,QSD]
RewriteRule ^go/force-gay/?$ https://k.related-dating.com/?abc=54fd14707fc517eb&xa=n&acme=wid.85377&media=seo&source=fgmsr&tpls=22 [R=302,L,NE,QSD]
RewriteRule ^go/rencontres-mixtes/?$ https://k.related-dating.com/?abc=dd2212b05a6a1175&xa=n&acme=wid.85377&media=seo&source=rmmsr&tpls=1 [R=302,L,NE,QSD]
RewriteRule ^go/spiice/?$ https://k.related-dating.com/?abc=c3f8507e3c11a948&xa=n&acme=wid.85377&media=seo&source=spmsr&ba=jW4&tpls=p78 [R=302,L,NE,QSD]
RewriteRule ^go/jm-messenger/?$ https://k.related-dating.com/?abc=fd83d3e1cd979ce0&xa=n&acme=wid.85377&media=seo&source=jmmmsr&tpls=2 [R=302,L,NE,QSD]

# ============================================================
# Pages d'erreur personnalisées
# ============================================================
ErrorDocument 404 /404.html

# ============================================================
# Compression Gzip
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE image/svg+xml application/font-woff application/font-woff2
</IfModule>

# ============================================================
# Cache navigateur
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType text/html                   "access plus 1 hour"
  ExpiresByType text/css                    "access plus 1 month"
  ExpiresByType application/javascript      "access plus 1 month"
  ExpiresByType text/javascript             "access plus 1 month"
  ExpiresByType image/jpeg                  "access plus 1 year"
  ExpiresByType image/png                   "access plus 1 year"
  ExpiresByType image/gif                   "access plus 1 year"
  ExpiresByType image/webp                  "access plus 1 year"
  ExpiresByType image/svg+xml               "access plus 1 year"
  ExpiresByType image/x-icon               "access plus 1 year"
  ExpiresByType application/font-woff      "access plus 1 year"
  ExpiresByType application/font-woff2     "access plus 1 year"
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType font/woff2                 "access plus 1 year"
</IfModule>

# ============================================================
# Headers de sécurité
# ============================================================
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ============================================================
# Interdire l'accès aux fichiers sensibles
# ============================================================
<FilesMatch "(^\.htaccess|^\.env|^\.gitignore|\.log$|\.bak$|\.old$|\.yml$)">
  Order allow,deny
  Deny from all
</FilesMatch>
